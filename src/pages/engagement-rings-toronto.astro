      "areaServed": {
        "@type": "City",
        "name": "Toronto",
        "containedInPlace": {"@type": "Province", "name": "Ontario", "containedInPlace": {"@type": "Country", "name": "Canada"}}
      },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://engagementringincanada.com/"},
          {"@type": "ListItem", "position": 2, "name": "Engagement Rings Toronto", "item": "https://engagementringincanada.com/engagement-rings-toronto/"}
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Do you have a showroom in Toronto?",
          "acceptedAnswer": {"@type": "Answer", "text": "No. Lux Jewels operates entirely online. Consultations are 30-40 minute video calls via Zoom or Google Meet. Rings deliver via FedEx Priority, fully insured, with signature required. The online process is faster, less expensive, and works better for a custom product than a showroom visit."}
        },
        {
          "@type": "Question",
          "name": "Why buy from an online jeweller instead of a Toronto showroom?",
          "acceptedAnswer": {"@type": "Answer", "text": "Lower overhead equals lower prices for equivalent quality. Toronto showroom rent, sales staff, and display inventory are real costs embedded in ring prices. An online specialist has lower overhead and passes savings to clients. You also work directly with the founder, not a commissioned salesperson, with access to stone inventory from multiple suppliers."}
        },
        {
          "@type": "Question",
          "name": "How does delivery work in Toronto?",
          "acceptedAnswer": {"@type": "Answer", "text": "All rings ship via FedEx Priority, fully insured, with signature required. Typical delivery to Toronto addresses is next-day from ship date. Tracking is provided at shipment. Custom orders take 4-6 weeks to produce before shipping."}
        },
        {
          "@type": "Question",
