const title = "Moissanite vs Lab-Grown Diamond — Which Is Right for You?";
const description = "Moissanite vs lab-grown diamond: fire, brilliance, hardness, price, and grading compared. Honest guide for Canadian buyers. By Suman Smith, Canada's first lab-grown specialist.";
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": "https://engagementringincanada.com/learn/moissanite-vs-lab-grown-diamond/",
      "headline": "Moissanite vs Lab-Grown Diamond — Which Is Right for You?",
