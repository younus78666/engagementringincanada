      "publisher": {"@type": "Organization", "name": "Lux Jewels"},
      "inLanguage": "en-CA",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://engagementringincanada.com/"},
          {"@type": "ListItem", "position": 2, "name": "Learn", "item": "https://engagementringincanada.com/learn/"},
          {"@type": "ListItem", "position": 3, "name": "Engagement Ring Metals Guide", "item": "https://engagementringincanada.com/learn/engagement-ring-metals-guide/"}
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {"@type": "Question", "name": "Does white gold require more maintenance than yellow gold?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. White gold needs rhodium replating every 1-2 years to maintain its bright white colour as the plating wears through daily wear. Yellow gold, rose gold, and platinum don't require replating."}},
        {"@type": "Question", "name": "Is platinum worth the extra cost for an engagement ring?", "acceptedAnswer": {"@type": "Answer", "text": "For clients who want a white metal without the maintenance of rhodium replating: yes. Platinum is naturally white, denser, and develops a patina over time. For clients comfortable with periodic replating, white gold achieves a similar appearance at lower upfront cost."}},
        {"@type": "Question", "name": "Does metal colour affect how a diamond looks?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, significantly. Warm metals (rose gold, yellow gold) make warmer-colour stones look whiter because the metal's warmth counteracts the stone's warmth. This means you can choose a lower (less expensive) colour grade in rose or yellow gold and achieve the same visual result as a higher grade in white gold or platinum."}},
        {"@type": "Question", "name": "What is the most durable metal for daily wear?", "acceptedAnswer": {"@type": "Answer", "text": "14K gold (any colour) is technically the hardest and most scratch-resistant of the common engagement ring metals. Platinum is very durable but develops a visible surface patina. 18K gold is softer than 14K. For active wearers, 14K gold is the most practical choice."}}
      ]
    }
  ]
});

const faqs = [
  {
    q: "Does white gold require more maintenance than yellow gold?",
    a: "Yes. White gold needs rhodium replating every 1-2 years to maintain its bright white colour. The underlying gold alloy shows through as the plating wears, creating a slightly warmer appearance. Yellow, rose, and platinum don't require replating."
  },
  {
    q: "Is platinum worth the extra cost?",
    a: "For clients who want a white metal and don't want to maintain rhodium plating: yes. Platinum is naturally white, heavier, and develops a beautiful patina. For clients who don't mind periodic replating, 14K or 18K white gold achieves the same appearance at a lower upfront cost."
  },
  {
    q: "Can I get rose gold in platinum?",
    a: "No. Platinum is always silvery-white. Rose gold and yellow gold are gold alloys - they can be 14K or 18K but not platinum. If you want a warm-toned metal, the choice is yellow or rose gold."
  },
  {
    q: "Does the metal affect the sparkle of the diamond?",
    a: "Not directly. But the metal colour affects the apparent colour of the diamond - especially with step-cut stones. Warm metals (rose, yellow) make warmer-colour stones look whiter, which can allow you to select a lower (less expensive) colour grade for the same visual appearance."
  },
];
