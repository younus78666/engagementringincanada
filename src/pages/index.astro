import TwoWaysCTA from '../components/TwoWaysCTA.astro';
import FAQSection from '../components/FAQSection.astro';

const title = "Engagement Rings Canada — Custom Lab-Grown Design";
const description = "Shop lab-grown engagement rings across Canada. IGI-certified diamonds and moissanite, custom design in 4-6 weeks. Free video consultation. Ships Canada-wide.";
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://engagementringincanada.com/",
      "url": "https://engagementringincanada.com/",
      "name": "Engagement Rings Canada - Custom Lab-Grown Design",
      "description": "Shop lab-grown engagement rings across Canada. IGI-certified diamonds and moissanite, custom design in 4-6 weeks. Free video consultation. Ships Canada-wide.",
      "inLanguage": "en-CA",
      "isPartOf": {
        "@id": "https://engagementringincanada.com/"
      }
    },
    {
      "@type": "Organization",
      "@id": "https://engagementringincanada.com/#org",
      "name": "Lux Jewels",
      "url": "https://engagementringincanada.com/",
      "foundingDate": "2007",
      "founder": {
        "@type": "Person",
        "name": "Suman Smith"
      },
      "description": "First Canadian lab-grown diamond specialist since 2015. Custom engagement ring design for Canada and the US.",
      "areaServed": ["CA", "US"],
      "serviceType": "Custom Engagement Ring Design"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Are lab-grown diamonds real diamonds?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Lab-grown diamonds have the same chemical composition, the same Mohs hardness of 10, and the same optical properties as mined diamonds. The only difference is origin. IGI grades them using the same 4Cs system."
          }
        },
        {
          "@type": "Question",
          "name": "How much do engagement rings cost in Canada?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A lab-grown diamond solitaire in Canada typically runs CA$800-CA$2,200 for the stone at 1 carat, plus setting and design costs. Natural diamonds of equivalent size run CA$6,000-CA$9,000 or more. Moissanite is the most affordable option, starting around CA$250-CA$600 per carat equivalent."
          }
        },
        {
          "@type": "Question",
          "name": "Can I get an engagement ring for under CA$1,000 in Canada?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. A moissanite stone in a 0.75-1ct equivalent size with a standard 14K solitaire setting is achievable in this budget. Lab-grown diamonds at 0.5ct are also possible."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between lab-grown and moissanite?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Lab-grown diamonds are diamonds. Moissanite is silicon carbide, a completely different material. Moissanite has a higher refractive index and produces more rainbow fire, slightly lower hardness at 9.25 vs 10, and a significantly lower price point. Both are durable enough for everyday wear."
          }
        },
        {
          "@type": "Question",
          "name": "Do you offer custom ring design?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. About 60% of rings built at Lux Jewels are fully custom. The process starts with a free video consultation, moves through CAD rendering and approval, then stone sourcing with an IGI report before you commit."
          }
        },
        {
          "@type": "Question",
          "name": "Do you ship across Canada?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Lux Jewels ships to all Canadian provinces via FedEx Priority, insured with signature required. Typical delivery is next-day once shipped. We also ship to the US."
          }
        },
        {
          "@type": "Question",
          "name": "What certifications do your diamonds come with?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "All lab-grown diamonds supplied by Lux Jewels come with an IGI grading certificate. The report number is laser-inscribed on the stone's girdle so you can independently verify the grade."
          }
        },
        {
          "@type": "Question",
          "name": "How long does a custom ring take?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "4-6 weeks from design approval. The CAD rendering and revision phase takes 5-7 business days. Casting and setting takes 10-15 business days. Shipping typically adds one business day."
          }
        },
        {
          "@type": "Question",
          "name": "What metal options are available?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "14K yellow, rose, or white gold; 18K yellow, rose, or white gold; platinum 950. All gold alloys use repurposed gold (99.5% previously refined)."
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://engagementringincanada.com/"
        }
      ]
    }
  ]
});

const faqs = [
  {
