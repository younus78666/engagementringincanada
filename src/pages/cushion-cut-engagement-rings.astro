---
import Base from '../layouts/Base.astro';
import TwoWaysCTA from '../components/TwoWaysCTA.astro';
import FAQSection from '../components/FAQSection.astro';

const title = "Cushion Cut Engagement Rings Canada — Lab-Grown Guide";
const description = "Shop cushion cut lab-grown engagement rings in Canada. Modern vs antique cushion explained, 2026 CAD pricing, which settings work best. Free video consultation. Ships Canada-wide.";
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://engagementringincanada.com/cushion-cut-engagement-rings/",
      "url": "https://engagementringincanada.com/cushion-cut-engagement-rings/",
      "name": "Cushion Cut Engagement Rings Canada — Lab-Grown Guide",
      "description": "Shop cushion cut lab-grown engagement rings in Canada. Modern vs antique cushion explained, 2026 CAD pricing, which settings work best. Free video consultation. Ships Canada-wide.",
      "inLanguage": "en-CA",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://engagementringincanada.com/"},
          {"@type": "ListItem", "position": 2, "name": "Lab-Grown Engagement Rings", "item": "https://engagementringincanada.com/lab-grown-engagement-rings/"},
          {"@type": "ListItem", "position": 3, "name": "Cushion Cut Engagement Rings", "item": "https://engagementringincanada.com/cushion-cut-engagement-rings/"}
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {"@type": "Question", "name": "What is the difference between modern and antique cushion cut diamonds?", "acceptedAnswer": {"@type": "Answer", "text": "Modern cushion has crushed ice facets producing high scattered sparkle, similar to round brilliant. Antique cushion has larger facets producing defined chunky flashes and more fire (coloured light). The light patterns look very different — modern for maximum sparkle, antique for distinctive fire and vintage aesthetic."}},
        {"@type": "Question", "name": "Is cushion cut the same as princess cut?", "acceptedAnswer": {"@type": "Answer", "text": "No. Princess cut is a square with sharp uncut corners and a chevron facet pattern. Cushion cut has rounded corners (the pillow shape) and can be square or rectangular. Cushion cut is more durable because sharp corners chip; cushion's rounded corners are more resistant."}},
        {"@type": "Question", "name": "What clarity grade do I need for cushion cut?", "acceptedAnswer": {"@type": "Answer", "text": "Modern cushion: VS2 is often acceptable because crushed ice facets scatter light and hide inclusions similarly to round brilliant. Antique cushion: VS1 is safer because larger facets can show inclusions more clearly. Always a stone-by-stone assessment."}},
        {"@type": "Question", "name": "What setting is most popular for cushion cut diamonds?", "acceptedAnswer": {"@type": "Answer", "text": "The halo is most popular for cushion cut, creating the 'double cushion' look. Solitaire is the most timeless option. Cushion cut is also strongly associated with vintage-inspired settings because it's the closest modern shape to the old mine cut used in Victorian jewellery."}},
        {"@type": "Question", "name": "How does cushion cut compare to oval in Canada?", "acceptedAnswer": {"@type": "Answer", "text": "Oval is elongated and finger-lengthening with a more modern connotation in Canada. Cushion is square/rectangular with a softer, more vintage-adjacent aesthetic. Both are priced below round at similar carat and grade levels."}}
      ]
    }
  ]
});

const faqs = [
  {
    q: "What is the difference between modern and antique cushion cut diamonds?",
    a: "Modern cushion (modified brilliant) has many small \"crushed ice\" facets in the pavilion that produce high sparkle and scattered light — similar to round brilliant. Antique cushion (old mine cut-inspired) has larger, fewer facets that produce defined flashes and more fire (coloured light). The light patterns look very different. Modern cushion is more common; antique cushion is more distinctive and suits vintage aesthetics."
  },
  {
    q: "Is cushion cut the same as princess cut?",
    a: "No. Princess cut is a square with sharp, uncut corners and a distinctive chevron-facet pattern. Cushion cut has rounded corners (the \"pillow\" shape). Cushion cut is generally more durable than princess cut because sharp corners are vulnerable to chipping. Cushion cut can also be rectangular, while princess cut is specifically square."
  },
  {
    q: "What clarity grade do I need for cushion cut?",
    a: "Modern cushion (crushed ice): VS2 is often acceptable, similar to round brilliant. Antique cushion: VS1 is safer because the larger facets are more transparency-like and can show inclusions more clearly. Always a stone-by-stone call for specific clarity features."
  },
  {
    q: "What setting is most popular for cushion cut diamonds?",
    a: "The halo is the most popular setting for cushion cut, creating the \"double cushion\" look. Solitaire in 4-prong is the most timeless option. Cushion cut is also one of the shapes most associated with vintage-inspired settings — the shape is closest to the old mine cut used in Victorian jewellery."
  },
  {
    q: "How does cushion cut compare to oval?",
    a: "Both are softer, more romantic shapes compared to rectangular step cuts. Oval is elongated and finger-lengthening; cushion is square/rectangular with a wider face-up profile. Oval has a more modern connotation in Canada right now; cushion is more classic and vintage-adjacent. In terms of value, both are priced below round at similar carat and grade levels. I've worked with both shapes extensively since 2015, when I founded Canada's first lab-grown specialist jewellery business."
  }
];
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <!-- HERO -->
  <section class="lj-hero">
    <div class="lj-hero__overlay"></div>
    <div class="lj-hero__content">
      <p class="lj-hero__eyebrow">Lux Jewels Canada</p>
      <h1>Cushion Cut Engagement Rings Canada</h1>
      <div class="lj-hero__ctas">
        <a href="https://luxjewels.com/booking-appointment/" target="_blank" rel="noopener" class="lj-hero-btn-primary">Book Free Consultation</a>
