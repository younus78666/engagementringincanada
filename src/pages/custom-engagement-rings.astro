const title = "Custom Engagement Rings Canada — Lab-Grown Design";
const description = "Design your own lab-grown engagement ring in Canada. 4-step CAD process, IGI-certified stones, free video consultation, and insured Canada-wide delivery.";
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://engagementringincanada.com/custom-engagement-rings/",
      "url": "https://engagementringincanada.com/custom-engagement-rings/",
      "name": "Custom Engagement Rings Canada — Lab-Grown Design",
      "description": "Design your own lab-grown engagement ring in Canada. 4-step CAD process, IGI-certified stones, free video consultation, and insured Canada-wide delivery.",
      "inLanguage": "en-CA",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://engagementringincanada.com/"},
          {"@type": "ListItem", "position": 2, "name": "Custom Engagement Rings", "item": "https://engagementringincanada.com/custom-engagement-rings/"}
        ]
      }
    },
    {
      "@type": "Service",
      "name": "Custom Engagement Ring Design",
      "serviceType": "Custom Jewelry Design",
      "provider": {
        "@type": "JewelryStore",
        "name": "Lux Jewels",
        "founder": {"@type": "Person", "name": "Suman Smith"},
        "foundingDate": "2007",
        "areaServed": ["CA", "US"]
      },
      "description": "Custom lab-grown engagement ring design service in Canada. 4-step CAD process, IGI-certified stones, free video consultation, 4-6 week delivery.",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "CAD",
        "availability": "https://schema.org/InStock"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How long does a custom engagement ring take at Lux Jewels?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The standard timeline is 4-6 weeks from your first consultation to delivery. Consultation and CAD design take 1-2 weeks. Stone sourcing takes 3-5 business days once the CAD is approved. Casting and setting take 10-15 business days. FedEx Priority shipping is typically next-day once dispatched."
          }
        },
        {
          "@type": "Question",
          "name": "How much does a custom engagement ring cost in Canada?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Custom rings at Lux Jewels start from the price confirmed at stan.store/luxjewels. The price depends on carat weight, stone type (lab-grown diamond or moissanite), metal choice, and setting complexity. Book a free consultation for a no-obligation quote."
          }
        },
        {
          "@type": "Question",
          "name": "Can I see the design before anything is made?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes - always. We provide a photorealistic CAD rendering for your approval before we source a single stone or pour any metal. Nothing is built until you approve the design."
          }
        },
        {
          "@type": "Question",
          "name": "Do you ship custom engagement rings across Canada?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. All orders ship via FedEx Priority, fully insured, with signature confirmation required. We ship to all Canadian provinces and to the US."
          }
        },
        {
          "@type": "Question",
          "name": "Do custom lab-grown rings cost less than natural diamond rings?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, significantly. Lab-grown diamonds cost 70-90% less than comparable natural diamonds, which means a custom lab-grown ring often costs less than a mass-produced natural diamond ring from a chain."
          }
        },
        {
          "@type": "Question",
          "name": "What metals do you use for custom engagement rings?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "14K and 18K yellow gold, white gold, and rose gold, plus platinum 950. All gold settings use repurposed gold (99.5% previously refined)."
          }
        },
        {
          "@type": "Question",
          "name": "Is there a warranty on custom engagement rings?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Contact Lux Jewels at shine@luxjewels.com for complete warranty terms on your custom ring."
          }
        }
      ]
    }
  ]
});

const faqs = [
  {
    q: "How long does a custom engagement ring take at Lux Jewels?",
    a: "The standard timeline is 4-6 weeks from your first consultation to delivery. Consultation and CAD design take 1-2 weeks. Stone sourcing takes 3-5 business days once the CAD is approved. Casting and setting take 10-15 business days. FedEx Priority shipping is typically next-day once dispatched. If you're working toward a specific date, tell us at consultation and we'll build the timeline from it."
  },
  {
    q: "How much does a custom engagement ring cost in Canada?",
    a: "Custom rings at Lux Jewels start from C$[OWNER INPUT] for a 0.5ct lab-grown diamond in 14K gold, including the stone, setting, IGI certificate, and insured delivery. The price depends on carat weight, stone type (lab-grown diamond or moissanite), metal choice (14K, 18K, or platinum), and setting complexity. Book a <a href='https://luxjewels.com/booking-appointment/' target='_blank' rel='noopener'>free consultation</a> for a no-obligation quote. Pricing subject to change. Confirm current rate at <a href='https://stan.store/luxjewels' target='_blank' rel='noopener'>stan.store/luxjewels</a> before booking."
  },
  {
    q: "Can I see the design before anything is made?",
    a: "Yes, always. We provide a photorealistic CAD rendering for your approval before we source a single stone or pour any metal. You can request adjustments at the CAD stage. Nothing is built until you're completely happy with the design."
  },
  {
    q: "Do you ship custom rings across Canada?",
    a: "Yes. All orders ship via FedEx Priority, fully insured, with signature confirmation required. We ship to all Canadian provinces and to the US."
  },
  {
    q: "Do custom lab-grown rings cost less than natural diamond rings?",
    a: "Yes, significantly. Lab-grown diamonds cost 70-90% less than comparable natural diamonds, which means a custom lab-grown ring often costs less than a mass-produced natural diamond ring from a chain. Custom doesn't mean expensive - it means made exactly for you."
  },
  {
    q: "What metals do you use for custom rings?",
