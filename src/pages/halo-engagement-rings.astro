---
import Base from '../layouts/Base.astro';
import TwoWaysCTA from '../components/TwoWaysCTA.astro';
import FAQSection from '../components/FAQSection.astro';

const title = "Halo Engagement Rings Canada — Lab-Grown Custom";
const description = "Shop halo lab-grown engagement rings in Canada. Standard halo vs hidden halo compared, 2026 CAD pricing, all shapes available. Free video consultation. Ships Canada-wide.";
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://engagementringincanada.com/halo-engagement-rings/",
      "url": "https://engagementringincanada.com/halo-engagement-rings/",
      "name": "Halo Engagement Rings Canada — Lab-Grown Custom",
      "description": "Shop halo lab-grown engagement rings in Canada. Standard halo vs hidden halo compared, 2026 CAD pricing, all shapes available. Free video consultation. Ships Canada-wide.",
      "inLanguage": "en-CA",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://engagementringincanada.com/"},
          {"@type": "ListItem", "position": 2, "name": "Lab-Grown Engagement Rings", "item": "https://engagementringincanada.com/lab-grown-engagement-rings/"},
          {"@type": "ListItem", "position": 3, "name": "Halo Engagement Rings", "item": "https://engagementringincanada.com/halo-engagement-rings/"}
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {"@type": "Question", "name": "What is the advantage of a halo engagement ring?", "acceptedAnswer": {"@type": "Answer", "text": "A halo setting makes the ring appear larger than the centre stone alone, adds significant perimeter sparkle, and creates a more elaborate look at the same centre stone carat weight. It adds 0.5-1.0mm to visible diameter on all sides."}},
        {"@type": "Question", "name": "What is a hidden halo engagement ring?", "acceptedAnswer": {"@type": "Answer", "text": "A hidden halo places smaller diamonds beneath the girdle of the centre stone, between the prongs. From above it looks like a solitaire; tilted sideways, the ring of accent diamonds is visible. It combines solitaire aesthetics from above with halo sparkle from the side."}},
        {"@type": "Question", "name": "Does a halo make a ring look bigger?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. A standard halo adds 0.5-1.0mm to the visible diameter. A 1.0ct round (6.5mm) in a halo can appear equivalent to a 1.25-1.5ct solitaire face-up."}},
        {"@type": "Question", "name": "What colour grade do I need for a halo ring?", "acceptedAnswer": {"@type": "Answer", "text": "G or better in white gold or platinum. The colourless accent stones in the halo can make a warmer centre stone appear more tinted by contrast. In yellow gold, H colour is more acceptable because the warm metal reduces the colour contrast."}}
      ]
    }
  ]
});

const faqs = [
  {
    q: "What is the advantage of a halo engagement ring?",
    a: "A halo setting makes the ring appear larger than the centre stone alone, adds significant perimeter sparkle, and creates a more elaborate look than a solitaire at the same centre stone carat weight. It's a good choice when visual impact per dollar is a priority."
  },
  {
    q: "What is a hidden halo engagement ring?",
    a: "A hidden halo places a ring of smaller diamonds beneath the girdle of the centre stone, between the prongs. From above, the ring looks like a plain solitaire. Tilted sideways, the hidden ring of diamonds becomes visible. It's a way to get halo sparkle without the visible crown frame."
  },
  {
    q: "Does a halo make the ring look bigger?",
    a: "Yes. A standard halo typically adds 0.5-1.0mm to the visible diameter of the ring on all sides. For a 1.0ct round diamond (6.5mm), a halo can make the ring appear equivalent in face-up size to a 1.25-1.5ct solitaire."
  },
  {
    q: "Do I need a better quality stone for a halo setting?",
    a: "The halo adds visual size but doesn't improve stone quality. G or better colour is recommended for halos in white gold or platinum, because the colourless halo accent stones can make a warmer centre look more tinted by contrast. VS2 or better clarity is standard."
  },
  {
    q: "How long does a halo engagement ring take?",
    a: "Custom halo rings take 4-6 weeks from stone selection to delivery. All Lux Jewels rings ship via FedEx Priority, fully insured, with signature required, to all Canadian provinces and the US. In 2015, I became Canada's first lab-grown jewellery specialist, and since then I've built halo rings for clients in every province."
  },
];
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <!-- HERO -->
  <section class="lj-hero">
    <div class="lj-hero__overlay"></div>
    <div class="lj-hero__content">
      <p class="lj-hero__eyebrow">Lux Jewels Canada</p>
      <h1>Halo Engagement Rings Canada — Lab-Grown Custom</h1>
      <div class="lj-hero__ctas">
        <a href="https://luxjewels.com/booking-appointment/" target="_blank" rel="noopener" class="lj-hero-btn-primary">Book Free Consultation</a>
        <a href="https://stan.store/luxjewels" target="_blank" rel="noopener" class="lj-hero-btn-secondary">No-BS Call - $199</a>
      </div>
    </div>
  </section>

  <!-- BREADCRUMB -->
  <div style="background:#f9f8f6;border-bottom:1px solid #e6e2de;">
