                  <td>C$[OWNER INPUT]</td>
                </tr>
                <tr>
                  <td>1.5ct cushion, G/VS2, 18K double halo</td>
                  <td>C$[OWNER INPUT]</td>
                </tr>
              </tbody>
            </table>
          </div>

