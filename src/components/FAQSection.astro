---
interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = 'Frequently Asked Questions' } = Astro.props;
---

<section class="lj-section lj-section-pad" style="background:#ffffff;">
  <div class="lj-container">
    <div class="lj-container--narrow" style="margin:0 auto;padding:0;">
      <p class="lj-subtitle">Have Questions?</p>
      <h2 class="lj-h2">{title}</h2>
      <hr class="lj-divider" />

      <div class="lj-faq__list">
        {items.map(item => (
          <div class="lj-faq__item">
            <button class="lj-faq__toggle" aria-expanded="false">
              <span class="lj-faq__q">{item.q}</span>
              <svg class="lj-faq__chevron" viewBox="0 0 14 14" aria-hidden="true">
                <path d="M2 4.5L7 9.5L12 4.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lj-faq__body">
              <p set:html={item.a} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
